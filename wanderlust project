<!DOCTYPE html>
<html>
<head>
<title>Wanderlust Tourism</title>

<style>

body{
font-family: 'Segoe UI', sans-serif;
margin:0;
background:#f5ebe0;
transition:0.5s;
}

/* HEADER */

header{
display:flex;
justify-content:space-between;
align-items:center;
background:#1f2933;
color:white;
padding:15px 40px;
}

header h1{
color:#d4a373;
}

nav a{
color:white;
margin:15px;
text-decoration:none;
font-weight:500;
}

nav a:hover{
color:#d4a373;
}

/* HERO */

.hero{
height:85vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
background:linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)),
url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e");
background-size:cover;
color:white;
text-align:center;
}

.hero h2{
font-size:55px;
letter-spacing:2px;
animation:fade 2s;
}

.hero p{
font-size:20px;
}

.btn{
background:#d4a373;
padding:12px 25px;
color:white;
border-radius:30px;
text-decoration:none;
margin-top:20px;
font-weight:bold;
}

/* DESTINATIONS */

.features{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:30px;
padding:60px;
}

.card{
background:white;
padding:25px;
border-radius:12px;
width:260px;
box-shadow:0 8px 20px rgba(0,0,0,0.15);
transition:0.4s;
text-align:center;
}

.card:hover{
transform:translateY(-10px);
}

/* FORM */

.form-box{
width:320px;
margin:auto;
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
text-align:center;
}

input{
width:90%;
padding:10px;
margin:10px;
border-radius:6px;
border:1px solid #ccc;
}

button{
padding:10px 20px;
background:#1f2933;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#d4a373;
}

/* DARK MODE */

.dark{
background:#111827;
color:white;
}

.dark .card{
background:#1f2933;
color:white;
}

/* FOOTER */

footer{
text-align:center;
padding:25px;
background:#1f2933;
color:#d4a373;
margin-top:40px;
}

/* ANIMATION */

@keyframes fade{
from{opacity:0;}
to{opacity:1;}
}

</style>


<script>

function toggleMode(){
document.body.classList.toggle("dark");
}

function suggest(){

let budget=document.getElementById("budget").value;

if(budget < 5000)
alert("Suggested Destination: Goa 🏖");

else if(budget < 15000)
alert("Suggested Destination: Bali 🌴");

else
alert("Suggested Destination: Switzerland 🏔");

}

function login(){

let user=document.getElementById("user").value;
let pass=document.getElementById("pass").value;

if(user=="admin" && pass=="1234")
alert("Login Successful!");

else
alert("Invalid Login");

}

</script>

</head>

<body>

<header>

<h1>Wanderlust</h1>

<nav>
<a href="#home">Home</a>
<a href="#destinations">Destinations</a>
<a href="#booking">Book</a>
<a href="#login">Login</a>
<a href="#" onclick="toggleMode()">Dark Mode</a>
</nav>

</header>


<section class="hero" id="home">

<h2>Explore The World With Wanderlust</h2>

<p>Luxury Travel • Unique Experiences • Unforgettable Memories</p>

<a href="#destinations" class="btn">Discover Destinations</a>

</section>


<section id="destinations">

<h2 style="text-align:center">Popular Destinations</h2>

<div class="features">

<div class="card">
<h3>🏖 Goa</h3>
<p>India's most famous beach destination.</p>
</div>

<div class="card">
<h3>🌴 Bali</h3>
<p>Tropical paradise with stunning temples.</p>
</div>

<div class="card">
<h3>🗼 Paris</h3>
<p>The romantic capital of the world.</p>
</div>

<div class="card">
<h3>🏔 Switzerland</h3>
<p>Snowy mountains and luxury resorts.</p>
</div>

</div>

</section>


<section id="booking">

<h2 style="text-align:center">Book Your Trip</h2>

<div class="form-box">

<input type="text" placeholder="Full Name">

<input type="text" placeholder="Destination">

<input type="number" id="budget" placeholder="Travel Budget">

<button onclick="suggest()">Suggest Destination</button>

<br><br>

<button>Book Now</button>

</div>

</section>


<section id="login">

<h2 style="text-align:center">User Login</h2>

<div class="form-box">

<input type="text" id="user" placeholder="Username">

<input type="password" id="pass" placeholder="Password">

<button onclick="login()">Login</button>

</div>

</section>


<footer>

<p>© 2026 Wanderlust Travel Company</p>

</footer>

</body>
</html>
