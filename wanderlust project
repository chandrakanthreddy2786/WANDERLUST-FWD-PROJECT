<!DOCTYPE html>
<html>
<head>
<title>Wanderlust Tourism</title>

<style>

body{
font-family: Arial;
margin:0;
background:#f4f4f4;
}

header{
background:#0b3d91;
color:white;
text-align:center;
padding:20px;
}

nav a{
margin:15px;
color:white;
text-decoration:none;
font-weight:bold;
}

section{
padding:40px;
text-align:center;
}

.hero{
background:url("https://source.unsplash.com/1600x600/?travel");
background-size:cover;
color:white;
padding:120px;
}

button{
padding:10px 20px;
background:#ff6600;
border:none;
color:white;
cursor:pointer;
border-radius:5px;
}

.features{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.card{
background:white;
padding:20px;
width:200px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
}

.places{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.place{
background:white;
padding:10px;
width:250px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
}

.place img{
width:100%;
border-radius:10px;
}

form{
display:flex;
flex-direction:column;
gap:10px;
width:300px;
margin:auto;
}

input,select{
padding:10px;
}

footer{
background:#0b3d91;
color:white;
text-align:center;
padding:10px;
margin-top:40px;
}

</style>

<script>

function login(){

var user=document.getElementById("username").value
var pass=document.getElementById("password").value

if(user=="admin" && pass=="1234")
alert("Login Successful")
else
alert("Invalid Login")

}

function bookTrip(){

var name=document.getElementById("name").value
var place=document.getElementById("destination").value

alert("Booking Confirmed for "+name+" to "+place)

}

</script>

</head>

<body>

<header>

<h1>🌍 WANDERLUST</h1>
<p>Explore the World with Smart Travel</p>

<nav>
<a href="#home">Home</a>
<a href="#destinations">Destinations</a>
<a href="#booking">Book Trip</a>
<a href="#login">Login</a>
</nav>

</header>

<section id="home" class="hero">

<h2>Discover Amazing Places</h2>
<p>Find the best destinations, hotels and food.</p>

<button onclick="location.href='#destinations'">Explore Now</button>

</section>

<section>

<h2>Our Services</h2>

<div class="features">

<div class="card">
<h3>✈️ Flight Booking</h3>
<p>Book flights easily.</p>
</div>

<div class="card">
<h3>🏨 Hotels</h3>
<p>Find the best hotels.</p>
</div>

<div class="card">
<h3>🍜 Food</h3>
<p>Discover famous foods.</p>
</div>

</div>

</section>

<section id="destinations">

<h2>Top Tourist Destinations</h2>

<div class="places">

<div class="place">
<img src="https://source.unsplash.com/400x250/?goa">
<h3>Goa</h3>
<p>Famous for beaches and nightlife.</p>
</div>

<div class="place">
<img src="https://source.unsplash.com/400x250/?mountain">
<h3>Manali</h3>
<p>Beautiful mountains and adventure.</p>
</div>

<div class="place">
<img src="https://source.unsplash.com/400x250/?paris">
<h3>Paris</h3>
<p>City of lights and romance.</p>
</div>

</div>

</section>

<section id="booking">

<h2>Book Your Trip</h2>

<form onsubmit="bookTrip(); return false;">

<input type="text" id="name" placeholder="Your Name" required>

<select id="destination">
<option>Goa</option>
<option>Manali</option>
<option>Paris</option>
</select>

<input type="date">

<button type="submit">Book Trip</button>

</form>

</section>

<section id="login">

<h2>User Login</h2>

<form onsubmit="login(); return false;">

<input type="text" id="username" placeholder="Username">

<input type="password" id="password" placeholder="Password">

<button type="submit">Login</button>

</form>

</section>

<footer>

<p>© 2026 Wanderlust Tourism | Explore the World</p>

</footer>

</body>
</html>
